{
    "name": "Workflow1",
    "activities": [
      {          
        "name": "start",
        "type": "page-activity",
        "components": [                           
          { "tag": "input", "id": "apicall.id" },
          { "tag": "input", "id": "apicall.title" },

          { "tag": "input", 
            "id": "registration.firstName", 
            "validators": [
              { "name": "Required", "message": "The field is required SDFSDFSDFSDFSDF" }
            ] 
          },

          { "tag": "moon-button", "id": "btn1", "value": "Next", "next": "page1" },
          { "tag": "moon-button", "id": "btn2", "value": "Decision", "next": "page3" },
          { "tag": "moon-button", "id": "btn3", "noValidate": true, "value": "Alert", "next": "page4" },
          { "tag": "moon-button", "id": "btn4", "noValidate": true, "value": "Api Call", "next": "page5" },
          { "tag": "moon-button", "id": "btn5", "noValidate": true, "value": "Code", "next": "page6" }
        ]    
      },

      {
        "name": "page1",
        "type": "assign-activity",
        "key" : "registration.testKey",
        "value": "Testing Assign",
        "next": "page1B"
      },

      {
        "name": "page1B",
        "type": "page-activity",
        "components": [                                   
          { "tag": "input", "id": "registration.lastName" },
          { "tag": "input", "id": "registration.firstName" },
          { "tag": "moon-button", "id": "btn6", "value": "Start", "next": "start" }          
        ]    
      },
      {
        "name": "page2",
        "type": "page-activity",
        "components": [                        
          { "tag": "input", "id": "page2", "value": "Page2" },
          { "tag": "moon-button", "id": "btn7", "value": "Start", "next": "start" }                    
        ]    
      },
      {
        "name": "page3",
        "type": "decision-activity",
        "left": "model.registration&&model.registration.firstName",
        "equality": "===",
        "right": "'Lourens'",
        "trueAction": "page2",
        "falseAction": "page1"
      },
      {
        "name": "page4",
        "type": "alert-activity",
        "message": "This is the alert activity"
      },
      {
        "name": "page5",
        "type": "api-activity",
        "url": "https://jsonplaceholder.typicode.com/posts/{apicall.id}",
        "method": "get",
        "mappings": [
          {"client" : "apicall.title", "remote": "title", "direction": "inout"}
        ],
        "next": "start"
      },
      {
        "name": "page6",
        "type": "code-activity",
        "expression": "alert(model.apicall&&model.apicall.title);",
        "next": "start"
      }
    ]
  }